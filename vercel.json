{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/shop", "destination": "/shop.html" },
    { "source": "/product", "destination": "/product.html" },
    { "source": "/cart", "destination": "/cart.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/order-status", "destination": "/order-status.html" },
    { "source": "/wishlist", "destination": "/wishlist.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/contact-success", "destination": "/contact-success.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/admin/invoices", "destination": "/admin/invoices.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
